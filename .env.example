# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Groq (for AI changelog post-commit hook)
VITE_GROQ_API_KEY=

# Single-team mode: when "true", hides all club/super-admin UI and routes so the
# app behaves as a single-team experience. Append ?admin=1 to any URL to
# temporarily re-enable the full UI for the current browser session (?admin=0
# clears the override). Omit or set to anything other than "true" for full mode.
VITE_SINGLE_TEAM_MODE=
